----------------------------------------------------
-- SLIDER LOGIC
----------------------------------------------------
local dragging = false

local function updateSlider(x)
	if not speedOn then return end

	local absX = sliderFrame.AbsolutePosition.X
	local sizeX = sliderFrame.AbsoluteSize.X

	local alpha = math.clamp((x - absX) / sizeX, 0, 1)
	local value = math.floor(alpha * SLIDER_MAX)

	currentWalkSpeed = value
	label.Text = "Speed: " .. value

	knob.Position = UDim2.new(alpha, 0, 0.5, -2)
end

sliderFrame.InputBegan:Connect(function(input)
	if not speedOn then return end
	if input.UserInputType == Enum.UserInputType.MouseButton1
	or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		updateSlider(input.Position.X)
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
	or input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
	end
end)

UIS.InputChanged:Connect(function(input)
	if not dragging then return end
	if not speedOn then return end
	if input.UserInputType == Enum.UserInputType.MouseMovement
	or input.UserInputType == Enum.UserInputType.Touch then
		updateSlider(input.Position.X)
	end
end)
