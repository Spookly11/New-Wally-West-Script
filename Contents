----------------------------------------------------
-- CLICK EFFECT
----------------------------------------------------
local function playClickEffect()
	local flash = TweenService:Create(speedButton, TweenInfo.new(0.1), {
		BackgroundColor3 = Color3.fromRGB(255,255,255)
	})

	local reset = TweenService:Create(speedButton, TweenInfo.new(0.2), {
		BackgroundColor3 = speedOn and Color3.fromRGB(0,120,160) or Color3.fromRGB(120,30,30)
	})

	local grow = TweenService:Create(speedButton, TweenInfo.new(0.1), {
		Size = UDim2.new(0,130,0,45)
	})

	local shrink = TweenService:Create(speedButton, TweenInfo.new(0.15), {
		Size = UDim2.new(0,120,0,40)
	})

	flash:Play()
	grow:Play()

	grow.Completed:Connect(function()
		shrink:Play()
		reset:Play()
	end)
end

