----------------------------------------------------
-- ANIMATION SPEED LOGIC
----------------------------------------------------

animBox.FocusLost:Connect(function()
	local value = tonumber(animBox.Text)

	if value and value > 0 then
		currentAnimSpeed = value
		animBox.Text = tostring(value)
	else
		-- reset to safe default if invalid input
		currentAnimSpeed = 1
		animBox.Text = "1"
	end
end)
----------------------------------------------------
-- MAIN LOOP
----------------------------------------------------
RunService.RenderStepped:Connect(function()
	local char = player.Character
	if not char then return end

	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum then return end

	if speedOn then
		hum.WalkSpeed = currentWalkSpeed
	else
		hum.WalkSpeed = 16
	end

	local animator = hum:FindFirstChild("Animator")
	if animator then
		for _, track in pairs(animator:GetPlayingAnimationTracks()) do
			pcall(function()
				track:AdjustSpeed(currentAnimSpeed)
			end)
		end
	end
end)

----------------------------------------------------
-- TOGGLE SPEED
----------------------------------------------------
local function toggleSpeed()
	local char = player.Character
	if not char then return end

	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum then return end

	speedOn = not speedOn

	if speedOn then
		speedButton.Text = "⚡ SPEED ON"
		speedButton.BackgroundColor3 = Color3.fromRGB(0,120,160)

		colorCorrection.Enabled = true
		setFOV(100)

		createElectricAura(char)
		soundActivate:Play()
	else
		speedButton.Text = "⚡ SPEED OFF"
		speedButton.BackgroundColor3 = Color3.fromRGB(120,30,30)

		colorCorrection.Enabled = false
		setFOV(70)

		destroyElectricAura()
		hum.WalkSpeed = 16
	end
end

speedButton.MouseButton1Click:Connect(function()
	playClickEffect()
	toggleSpeed()
end)

